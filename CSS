body {
    font-family: Arial, sans-serif;
    margin: 0;
    background-color: #ffffff;
    color: #000000;
}

header {
    background-color: #111111;
    text-align: center;
    padding: 5px;
    border-bottom: 2px solid rgb(0, 26, 255);
}

nav {
    background-color: #505050;
    padding: 10px;
    text-align: center;
}

nav a {
    color: #fffefe;
    margin: 0 15px;
    text-decoration: none;
    font-weight: bold;
}

nav a:hover {
    text-decoration: underline;
}

section {
    padding: 20px;
    max-width: 800px;
    margin: auto;
}

h2 {
    color: #000c77; 
}
 
 h1   {
    color: #ffffff;
}

h5   {
    color: #ffffff;
}

h4   {
    color: #ffffff;
}

ul {
    list-style-type: square;
}

footer {
    background-color: #1b1b1b;
    text-align: center;
    padding: 1px;
    margin-top: 20px;
    border-top: 2px solid rgb(50, 0, 187);
}









                     .container-cards {
                    display: grid;
                    grid-template-columns: repeat(4, 1fr);
                    gap: 20px;
                    max-width: 1200px;
                    justify-content: center;
                    margin: 30px auto;
                    padding: 0 20px;
                     }
                     .card {
                    box-shadow: 0 4px 8px 0 rgba(0,0,0,0.2);
                    transition: 0.3s;
                    width: 100%;
                    border-radius: 10px;
                    overflow: hidden; 
                    font-family: Arial, sans-serif;
                    background-color: white;
                }
                .card-botao {
                    display: block;
                    text-decoration: none;
                    color: #2c3e50;
                    background-color: #ffffff;
                    padding: 40px 30px;
                    border-radius: 16px;
                    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
                    width: 100%;
                    max-width: 350px;
                    text-align: center;
                    cursor: pointer;
                    transition: all 0.2s ease-in-out;
                }
                .card-botao:hover {
                    transform: scale(1.03);
                    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.12);
                    background-color: #fcfcfc;
                }
                .card-botao:active {
                    transform: scale(0.98);
                }
                .card:hover {
                    box-shadow: 0 8px 16px 0 rgba(0,0,0,0.2);
                }
                .card-image {
                    width: 100%;
                    height: 200px;
                    object-fit: cover; 
                    display: block;    
                }

                .card-content {
                    padding: 16px;
                }

                .card-title {
                    margin: 0 0 10px 0;
                    font-size: 20px;
                    color: #333;
                }

                .card-description {
                    margin: 5px;
                    font-size: 14px;
                    color: #666;
                    line-height: 1.5;
                }

                @media (max-width: 900px) {
                    .container-cards {
                        grid-template-columns: repeat(2, 1fr);
                    }
                }

                @media (max-width: 600px) {
                    .container-cards {
                        grid-template-columns: 1fr;
                    }
                }         
